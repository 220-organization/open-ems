DATABASE_URL=postgresql+asyncpg://openems:openems@localhost:5433/openems

# Sliding-window rate limit per IP (60s); /health and /static/* are excluded
# RATE_LIMIT_ENABLED=1
# RATE_LIMIT_PER_IP_PER_MINUTE=200

# Docker Compose: API uses OPEN_EMS_SERVE_SPA=0 (set in compose). Optional: bake a public API URL into the UI image build:
# REACT_APP_API_BASE_URL=https://your-host:9221

# Upstream for /api/b2b/* proxy (B2B public REST)
B2B_API_BASE_URL=https://220-km.com:8080

# Deye Cloud Open API — inverter list for Power flow (same plants as https://www.deyecloud.com/business/maintain/plant)
# Register an app at https://developer.deyecloud.com/app — use App ID + App Secret, account email, and login password (plain; server sends SHA-256 to Deye).
# DEYE_API_BASE_URL=https://eu1-developer.deyecloud.com/v1.0
# DEYE_APP_ID=
# DEYE_APP_SECRET=
# DEYE_EMAIL=
# DEYE_PASSWORD=
# DEYE_COMPANY_ID=0
# Snapshot SoC for all inverters to Postgres (5-minute buckets, UTC) for DAM chart history
# DEYE_SOC_SNAPSHOT_ENABLED=1
# DEYE_SOC_SNAPSHOT_INTERVAL_SEC=300
# POST /strategy/dynamicControl template (Discharge 2% button) — long HTTP; raise proxy_read_timeout
# DEYE_DYNAMIC_CONTROL_RATED_POWER_W=10000
# DEYE_DISCHARGE_SOC_POLL_SEC=15
# DEYE_DISCHARGE_SOC_TIMEOUT_SEC=14400
# Peak DAM: backend scheduler — 2% discharge at Kyiv hour of today’s DAM max (DB), once per (day, inverter, peak hour) on success
# DEYE_PEAK_AUTO_DISCHARGE_SCHEDULER_ENABLED=1
# DEYE_PEAK_AUTO_DISCHARGE_INTERVAL_SEC=600
# DEYE_LOW_DAM_CHARGE_SCHEDULER_ENABLED=1
# DEYE_LOW_DAM_CHARGE_INTERVAL_SEC=600
# EV port: plant/device label must include ``evport<station>`` (e.g. evport738); polls B2B station status, SELLING_FIRST at job powerWt (requires DEYE_* credentials)
# DEYE_EV_PORT_EXPORT_INTERVAL_SEC=30
# EV_PORT_DEVICE_CLIENT_UI_ID=dtbhrny
# DEYE_EV_PORT_EXPORT_TOU_SOC_PCT=15

# Huawei FusionSolar Northbound — plant list + real-time KPI for Power flow (read-only Basic APIs)
# Portal: System → Company Management → Northbound Management → Add user
# HUAWEI_BASE_URL=https://eu5.fusionsolar.huawei.com
# HUAWEI_USER_NAME=
# HUAWEI_SYSTEM_CODE=
# Optional: skip getDevList discovery (Northbound device ids from FusionSolar / Postman getDevList)
# HUAWEI_METER_DEV_ID=1000000256081734
# HUAWEI_METER_DEV_TYPE_ID=47
# HUAWEI_INVERTER_DEV_ID=1000000256081652
# HUAWEI_INVERTER_DEV_TYPE_ID=1
# Optional: last successful station list on disk when Northbound returns failCode 407 (default on; TTL default 7 days)
# HUAWEI_DISK_CACHE_ENABLED=1
# HUAWEI_STATION_LIST_DISK_TTL_SEC=604800
# After 407 with no list to return, skip further getStationList calls for this many seconds (default 300)
# HUAWEI_STATION_LIST_COOLDOWN_AFTER_407_SEC=300
# HUAWEI_CACHE_DIR=/path/to/writable/dir
# Snapshot PV/grid/load (W) from getDevRealKpi to Postgres every 5 minutes by default (UTC 5-min buckets; same idea as DEYE_SOC_SNAPSHOT)
# HUAWEI_POWER_SNAPSHOT_ENABLED=1
# HUAWEI_POWER_SNAPSHOT_INTERVAL_SEC=300

# OREE DAM prices — sync into open-ems DB; DAM chart reads DB only (GET /api/dam/chart-day)
# OREE_API_BASE_URL=https://api.oree.com.ua/index.php/api
# OREE_API_DAM_PRICES_PATH=/damprices
# OREE_API_DAM_INDEXES_PATH=/damindexes
# DAM indices (DAY/NIGHT/PEAK/…) stored in oree_dam_index; GET /api/dam/damindexes?date= reads DB first
# OREE_API_KEY=
# OREE_COMPARE_ZONE_EIC=10Y1001C--000182
# Scheduled OREE → oree_dam_price at Europe/Kiev (background; default hours 12,13,14,15; skip if tomorrow already has 24/24 in DB)
# OREE_DAM_DAILY_SYNC_ENABLED=1
# OREE_DAM_SYNC_HOURS_KYIV=12,13,14,15
# Legacy single hour if OREE_DAM_SYNC_HOURS_KYIV unset: OREE_DAM_DAILY_SYNC_HOUR_KYIV=15
# OREE_DAM_DAILY_SYNC_MINUTE_KYIV=0
# Optional: allow operators to POST /api/dam/sync (default off — UI/chart-day never pull OREE)
# OREE_DAM_MANUAL_SYNC_ENABLED=0
# On-demand OREE when opening chart-day for Kyiv-tomorrow with empty DB (default 5; 0 = off)
# OREE_DAM_LAZY_FETCH_MAX=5

# ENTSO-E Transparency DAM (EUR/MWh) — default Spain; see docs/ENTSOE_TRANSPARENCY_DAM.md
# ENTSOE_API_BASE_URL=https://web-api.tp.entsoe.eu/api
# ENTSOE_SECURITY_TOKEN=
# User-Agent for Transparency API (ENTSO-E recommends contact info)
# ENTSOE_HTTP_USER_AGENT=OpenEMS/1.0 (open-ems; ENTSO-E Transparency)
# Optional: additional ENTSO-E zone EICs (comma-separated). ES, PL, and Ukraine are always synced without this.
# ENTSOE_DAM_ZONE_EICS=
# ENTSOE_DAM_DAILY_SYNC_ENABLED=1
# Skip scheduled pull when all zones have 24h data (default off — refresh ES+PL every window)
# ENTSOE_DAM_DAILY_SYNC_SKIP_IF_COMPLETE=0
# ENTSOE_DAM_SYNC_HOURS_BRUSSELS=12,13,14,15
# ENTSOE_DAM_DAILY_SYNC_MINUTE_BRUSSELS=0
# ENTSOE_DAM_MANUAL_SYNC_ENABLED=0
# On-demand ENTSO-E pull when GET /api/dam/entsoe/chart-day finds empty DB (default on)
# ENTSOE_CHART_DAY_LAZY_FETCH=1
