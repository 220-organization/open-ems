DATABASE_URL=postgresql+asyncpg://openems:openems@localhost:5433/openems

# Sliding-window rate limit per IP (60s); /health and /static/* are excluded
# RATE_LIMIT_ENABLED=1
# RATE_LIMIT_PER_IP_PER_MINUTE=200

# Docker Compose: API uses OPEN_EMS_SERVE_SPA=0 (set in compose). Optional: bake a public API URL into the UI image build:
# REACT_APP_API_BASE_URL=https://your-host:9221

# Upstream for /api/b2b/* proxy (B2B public REST)
B2B_API_BASE_URL=https://220-km.com:8080

# Deye Cloud Open API — inverter list for Power flow (same plants as https://www.deyecloud.com/business/maintain/plant)
# Register an app at https://developer.deyecloud.com/app — use App ID + App Secret, account email, and login password (plain; server sends SHA-256 to Deye).
# DEYE_API_BASE_URL=https://eu1-developer.deyecloud.com/v1.0
# DEYE_APP_ID=
# DEYE_APP_SECRET=
# DEYE_EMAIL=
# DEYE_PASSWORD=
# DEYE_COMPANY_ID=0
# Snapshot SoC for all inverters to Postgres (5-minute buckets, UTC) for DAM chart history
# DEYE_SOC_SNAPSHOT_ENABLED=1
# DEYE_SOC_SNAPSHOT_INTERVAL_SEC=300
# POST /strategy/dynamicControl template (Discharge 2% button) — long HTTP; raise proxy_read_timeout
# DEYE_DYNAMIC_CONTROL_RATED_POWER_W=10000
# DEYE_DISCHARGE_SOC_POLL_SEC=15
# DEYE_DISCHARGE_SOC_TIMEOUT_SEC=14400
# Peak DAM: backend scheduler — 2% discharge at Kyiv hour of today’s DAM max (DB), once per (day, inverter, peak hour) on success
# DEYE_PEAK_AUTO_DISCHARGE_SCHEDULER_ENABLED=1
# DEYE_PEAK_AUTO_DISCHARGE_INTERVAL_SEC=600
# DEYE_LOW_DAM_CHARGE_SCHEDULER_ENABLED=1
# DEYE_LOW_DAM_CHARGE_INTERVAL_SEC=600

# OREE DAM prices — sync into open-ems DB; DAM chart reads DB only (GET /api/dam/chart-day)
# OREE_API_BASE_URL=https://api.oree.com.ua/index.php/api
# OREE_API_DAM_PRICES_PATH=/damprices
# OREE_API_DAM_INDEXES_PATH=/damindexes
# DAM indices (DAY/NIGHT/PEAK/…) stored in oree_dam_index; GET /api/dam/damindexes?date= reads DB first
# OREE_API_KEY=
# OREE_COMPARE_ZONE_EIC=10Y1001C--000182
# Scheduled OREE → oree_dam_price at Europe/Kiev (background; default hours 12,13,14,15; skip if tomorrow already has 24/24 in DB)
# OREE_DAM_DAILY_SYNC_ENABLED=1
# OREE_DAM_SYNC_HOURS_KYIV=12,13,14,15
# Legacy single hour if OREE_DAM_SYNC_HOURS_KYIV unset: OREE_DAM_DAILY_SYNC_HOUR_KYIV=15
# OREE_DAM_DAILY_SYNC_MINUTE_KYIV=0
# Optional: allow operators to POST /api/dam/sync (default off — UI/chart-day never pull OREE)
# OREE_DAM_MANUAL_SYNC_ENABLED=0
# On-demand OREE when opening chart-day for Kyiv-tomorrow with empty DB (default 10; 0 = off)
# OREE_DAM_LAZY_FETCH_MAX=10
