# Server-side env for docker-compose.deploy.yml (copy to .env next to the compose file).

# Set by CI on each deploy; for manual runs use your GHCR image (owner must be lowercase).
# OPEN_EMS_IMAGE=ghcr.io/your-github-username/open-ems:abc1234fullsha
#
# If the GHCR package is private, configure GitHub Actions secrets GHCR_PULL_TOKEN (read:packages PAT)
# and GHCR_PULL_USERNAME (GitHub username for that PAT) so the deploy host can docker login.

POSTGRES_USER=openems
POSTGRES_PASSWORD=change-me
POSTGRES_DB=openems

# Host port mapping (container listens on 8090)
OPEN_EMS_HOST_PORT=8090

B2B_API_BASE_URL=https://220-km.com:8080
