# Same pattern as admin-portal/ui/.env — URL of the Open EMS FastAPI process
REACT_APP_API_BASE_URL=http://127.0.0.1:9221

# Optional analytics (same Microsoft Clarity / Google stack as 220-km.com — set at build time for Docker)
# Production Clarity project (220-km main web): opcn7h9p5n | staging: opco080tcx
REACT_APP_CLARITY_PROJECT_ID=
# Google Analytics: GA4 measurement ID (G-…) or legacy Universal (UA-…) — e.g. UA-246535650-1 prod / UA-246535650-2 stage on 220-km
REACT_APP_GA_MEASUREMENT_ID=
