# Same pattern as admin-portal/ui/.env — URL of the Open EMS FastAPI process
REACT_APP_API_BASE_URL=http://127.0.0.1:9221

# Optional analytics — set at build time for Docker / CI (leave empty to disable)
# Microsoft Clarity: project ID from clarity.microsoft.com
REACT_APP_CLARITY_PROJECT_ID=
# Google Analytics: GA4 measurement ID (G-…) or legacy Universal (UA-…)
REACT_APP_GA_MEASUREMENT_ID=
